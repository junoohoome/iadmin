# iAdmin 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件不要提交到 Git 仓库！

# ==================== 数据库配置 ====================
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== Druid 监控配置 ====================
DRUID_USERNAME=admin
DRUID_PASSWORD=your_druid_password_here

# ==================== JWT 配置 ====================
# 必须使用至少88位的Base64编码字符串
# 生成方式: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=your_jwt_secret_here

# ==================== RSA 密钥配置 ====================
# 生成方式: 使用 OpenSSL 或在线工具生成 RSA 密钥对
# 公钥用于前端加密密码，私钥用于后端解密
RSA_PRIVATE_KEY=your_rsa_private_key_here
RSA_PUBLIC_KEY=your_rsa_public_key_here

# ==================== Druid 连接池配置（可选）====================
# DRUID_INITIAL_SIZE=50
# DRUID_MIN_IDLE=50
# DRUID_MAX_ACTIVE=300

# ==================== Redis 连接池配置（可选）====================
# REDIS_MAX_ACTIVE=200
# REDIS_MAX_IDLE=100
# REDIS_MIN_IDLE=50
